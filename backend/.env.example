# 复制本文件为 .env 并按需修改

# 数据库：默认 SQLite，开箱即用；要用 MySQL 改成
# DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/wxwork_analytics
DATABASE_URL=sqlite:///./wxwork_analytics.db

# JWT 密钥（生产务必改成随机长字符串）
SECRET_KEY=change-me-to-a-long-random-secret-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 默认企业微信 CorpID（可留空，登录时由前端传入）
WX_CORP_ID=

# 跨域允许的前端地址
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 演示模式：true 时无企微凭证也可生成模拟数据
DEMO_MODE=true

# 豆包大模型（火山方舟 Ark）—— 用于群消息情绪分析，留空则该功能不可用
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 填你在方舟控制台创建的「推理接入点 ID」（ep-xxxx）或模型名
DOUBAO_MODEL=doubao-pro-32k

# 新智慧 NextSLS TMS MPAPI —— 查件/运单。密钥在「员工API密钥」创建，联系新智慧客服获取
NEXTSLS_TOKEN=
NEXTSLS_BASE_URL=https://zjyxgj.nextsls.com/mpapi/v5

# 企业微信「会话内容存档」(仅Linux服务器, 需原生SDK; 本地Windows留空即可)
WX_ARCHIVE_CORPID=
WX_ARCHIVE_SECRET=
WX_ARCHIVE_SDK_PATH=/opt/wxwork_analytics/sdk/libWeWorkFinanceSdk_C.so
WX_ARCHIVE_PRIVATE_KEY_PATH=/opt/wxwork_analytics/secrets/wx_archive_private_key.pem

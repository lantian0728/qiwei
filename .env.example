# ===== 生产部署用（docker-compose 读取）=====
# 复制本文件为 .env 并填写真实值。.env 已被 .gitignore 忽略，不会提交。

# 数据库
MYSQL_ROOT_PASSWORD=请改成强密码
MYSQL_DATABASE=wxwork_analytics

# 后端
SECRET_KEY=请改成一长串随机字符串
DEMO_MODE=false
WX_CORP_ID=
CORS_ORIGINS=https://wx.zjyxgj.com

# 对外端口（1Panel/Nginx 再反代到这个端口并配 HTTPS）
HTTP_PORT=8080

# 豆包大模型（火山方舟）
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-32k
